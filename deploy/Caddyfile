tracker.melindapascoeneurology.com {
	encode zstd gzip

	reverse_proxy 127.0.0.1:3000 {
		health_uri /health
		health_interval 30s
		health_timeout 5s
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		-Server
	}
}
